    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VMA4.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="V4" type="revolute">
    <origin xyz="-0.2132 -0.0020556 -0.11969" rpy="0.66553 1.1999 2.3639"/>
    <parent>base_link</parent>
    <child>VMA4</child>
    <axis xyz="0.32628 0 -0.94527"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="10"/>
  </joint>

  <!-- ==================== МОТОР VMA5 (вертикальный) ==================== -->
  <link name="VMA5">
    <inertial>
      <origin xyz="1.4388E-06 -5.3688E-07 0.012702" rpy="0 0 0"/>
      <mass value="0.0077401"/>
      <inertia ixx="2.2065E-06" ixy="8.4966E-11" ixz="-1.4646E-11" iyy="2.2079E-06" iyz="-9.6038E-12" izz="3.2149E-06"/>
