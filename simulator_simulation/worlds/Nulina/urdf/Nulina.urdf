    <parent>base_link</parent>
    <child>VMA5</child>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="10"/>
  </joint>

  <!-- ==================== МОТОР VMA6 (вертикальный) ==================== -->
  <link name="VMA6">
    <inertial>
      <origin xyz="1.8113E-06 -1.3867E-06 0.012701" rpy="0 0 0"/>
      <mass value="0.0077405"/>
      <inertia ixx="2.2064E-06" ixy="-2.1165E-10" ixz="-1.9083E-11" iyy="2.208E-06" iyz="-1.0478E-11" izz="3.2149E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
