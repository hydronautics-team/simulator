  </link>
  <joint name="V3" type="revolute">
    <origin xyz="-0.2132 0.03568 0.093266" rpy="3.0222 0.62088 -1.7086"/>
    <parent>base_link</parent>
    <child>VMA3</child>
    <axis xyz="0.32628 0 -0.94527"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="10"/>
  </joint>

  <!-- ==================== МОТОР VMA4 (наклонный) ==================== -->
  <link name="VMA4">
    <inertial>
      <origin xyz="-0.00018085 2.2982E-08 0.00052658" rpy="0 0 0"/>
      <mass value="0.0065042"/>
      <inertia ixx="1.2858E-06" ixy="-1.9268E-11" ixz="-5.7906E-08" iyy="1.269E-06" iyz="-5.9824E-12" izz="1.4334E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VMA4.STL"/>
