<?xml version="1.0"?>
<robot name="Nulina">

  <!-- ==================== ОСНОВНОЙ КОРПУС ==================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0021431 -1.2748E-05 0.00090226" rpy="0 0 0"/>
      <mass value="16.017"/>
      <inertia ixx="0.036011" ixy="-1.0287E-07" ixz="-3.3251E-06" iyy="0.13679" iyz="1.8461E-07" izz="0.15367"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- ==================== МОТОР VMA1 (наклонный) ==================== -->
  <link name="VMA1">
    <inertial>
      <origin xyz="-0.0046001 -1.6795E-06 0.013337" rpy="0 0 0"/>
      <mass value="0.0065048"/>
      <inertia ixx="1.286E-06" ixy="-7.1416E-11" ixz="-5.7759E-08" iyy="1.2688E-06" iyz="-5.7783E-11" izz="1.4336E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VMA1.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VMA1.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="V1" type="revolute">
    <origin xyz="0.2278 -0.013157 0.11254" rpy="0.57206 -0.45025 -2.2456"/>
    <parent>base_link</parent>
    <child>VMA1</child>
    <axis xyz="0.32628 0 -0.94527"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="10"/>
  </joint>

  <!-- ==================== МОТОР VMA2 (наклонный) ==================== -->
  <link name="VMA2">
    <inertial>
      <origin xyz="-0.019885 -2.5266E-06 0.05761" rpy="0 0 0"/>
      <mass value="0.0065055"/>
      <inertia ixx="1.2862E-06" ixy="-5.5244E-11" ixz="-5.7836E-08" iyy="1.2689E-06" iyz="-6.6579E-12" izz="1.4337E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VMA2.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/VMA2.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="V2" type="revolute">
    <origin xyz="0.2278 -0.051523 -0.085674" rpy="2.4918 0.38742 -2.3437"/>
    <parent>base_link</parent>
    <child>VMA2</child>
    <axis xyz="0.32628 0 -0.94527"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="10"/>
  </joint>

  <!-- ==================== МОТОР VMA3 (наклонный) ==================== -->
  <link name="VMA3">
    <inertial>
      <origin xyz="0.01484825 -3.5948E-06 -0.04302015" rpy="0 0 0"/>
      <mass value="0.006504"/>
      <inertia ixx="1.2859E-06" ixy="1.9215E-10" ixz="-5.7903E-08" iyy="1.2689E-06" iyz="-4.1459E-11" izz="1.4334E-06"/>
    </inertial>
    <visual>
