      </geometry>
    </collision>
  </link>
  <joint name="V6" type="revolute">
    <origin xyz="0.0090358 -0.00335 -0.18999" rpy="1.5708 0.8797 1.5708"/>
    <parent>base_link</parent>
    <child>VMA6</child>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="10"/>
  </joint>

  <!-- ==================== ГИДРОДИНАМИКА (сопротивление воды) ==================== -->
  <gazebo>
    <plugin filename="gz-sim-hydrodynamics-system" name="gz::sim::systems::Hydrodynamics">
      <link_name>base_link</link_name>
      <fluid_density>900</fluid_density>
    </plugin>
  </gazebo>

  <!-- ==================== ПЛАГИНЫ МОТОРОВ (Thrusters) ==================== -->
  <gazebo>
    <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
      <joint_name>V1</joint_name>
      <thrust_coefficient>0.004422</thrust_coefficient>
      <fluid_density>1000</fluid_density>
      <propeller_diameter>0.1</propeller_diameter>
      <command_topic>thrust/V1</command_topic>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
      <joint_name>V2</joint_name>
      <thrust_coefficient>0.004422</thrust_coefficient>
      <fluid_density>1000</fluid_density>
      <propeller_diameter>0.1</propeller_diameter>
      <command_topic>thrust/V2</command_topic>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
      <joint_name>V3</joint_name>
      <thrust_coefficient>0.004422</thrust_coefficient>
      <fluid_density>1000</fluid_density>
      <propeller_diameter>0.1</propeller_diameter>
      <command_topic>thrust/V3</command_topic>
    </plugin>
