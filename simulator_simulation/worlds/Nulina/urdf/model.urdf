  <joint name="V2" type="revolute">
    <origin xyz="0.394 -0.049023 -0.085674" rpy="2.4918 0.38742 -2.3437"/>
    <parent>base_link</parent><child>VMA2</child>
    <axis xyz="0.32628 0 -0.94527"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="10"/>
  </joint>

  <!-- VMA3 -->
