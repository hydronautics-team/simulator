    <origin xyz="-0.047 0.03818 0.093266" rpy="3.0222 0.62088 -1.7086"/>
    <parent>base_link</parent><child>VMA3</child>
    <axis xyz="0.32628 0 -0.94527"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="10"/>
