<?xml version="1.0"?>
<robot name="Nulina">

  <!-- КОРПУС -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.16834 -1.2748E-05 -0.0015977" rpy="0 0 0"/>
      <mass value="16.017"/>
      <inertia ixx="0.036011" ixy="0" ixz="0" iyy="0.13679" iyz="0" izz="0.15367"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- VMA1 -->
  <link name="VMA1">
    <inertial>
      <mass value="0.0065"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="meshes/VMA1.STL"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="meshes/VMA1.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="V1" type="revolute">
    <origin xyz="0.394 -0.010657 0.11254" rpy="0.57206 -0.45025 -2.2456"/>
    <parent>base_link</parent>
    <child>VMA1</child>
    <axis xyz="0.32628 0 -0.94527"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="10"/>
  </joint>

  <!-- VMA2 -->
  <link name="VMA2">
    <inertial><mass value="0.0065"/><inertia ixx="1e-6" iyy="1e-6" izz="1e-6"/></inertial>
