####### Compile

main.o: main.cpp widget.h \
		ui_widget.h \
		widget3d.h \
		ui_widget3d.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cpp

widget.o: widget.cpp widget.h \
		ui_widget.h \
		widget3d.h \
		ui_widget3d.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o widget.o widget.cpp

widget3d.o: widget3d.cpp widget3d.h \
		ui_widget3d.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o widget3d.o widget3d.cpp

qrc_BG.o: qrc_BG.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o qrc_BG.o qrc_BG.cpp

moc_widget.o: moc_widget.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_widget.o moc_widget.cpp

moc_widget3d.o: moc_widget3d.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_widget3d.o moc_widget3d.cpp

####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/untitled2/bin || mkdir -p $(INSTALL_ROOT)/opt/untitled2/bin
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/opt/untitled2/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/opt/untitled2/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/untitled2/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/untitled2/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

